# Server
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/learnflow

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=learnflow-sources

# Gemini API
GOOGLE_AI_API_KEY=your-gemini-api-key-here

# Auth0 — replaces JWT_SECRET
# Domain from Auth0 dashboard (no https://, no trailing slash)
AUTH0_DOMAIN=YOUR_DOMAIN.auth0.com
# Must match AUTH0_AUDIENCE in frontend .env.local
AUTH0_AUDIENCE=https://api.learnflow.ai

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@learnflow.ai

# Optional: Production speech APIs (used when upgrading from Web Speech API)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
