# Server
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/learnflow

# Redis
REDIS_URL=redis://localhost:6379

# Gemini API
GOOGLE_AI_API_KEY= AIzaSyDLvHWrXXrM-DB_XC3jIMYC7Id_3V02ILk

# Auth0 — replaces JWT_SECRET
# Domain from Auth0 dashboard (no https://, no trailing slash)
