# Must match AUTH0_AUDIENCE in frontend .env.local
AUTH0_AUDIENCE=https://api.learnflow.ai

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@learnflow.ai

# Optional: Production speech APIs (used when upgrading from Web Speech API)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
