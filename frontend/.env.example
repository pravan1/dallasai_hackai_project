# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth0 — https://auth0.com/docs/quickstart/webapp/nextjs
# Generate AUTH0_SECRET with: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_DOMAIN.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# API identifier registered in the Auth0 dashboard (matches backend AUTH0_AUDIENCE)
AUTH0_AUDIENCE=https://api.learnflow.ai

# Optional: Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
